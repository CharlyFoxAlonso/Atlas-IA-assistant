# Atlas v4.1 - configuración de ejemplo
# Copiá este archivo como .env y completá únicamente lo que vayas a usar.
# Nunca publiques el archivo .env real.

# Motor principal: atlas | prometeo | groq
MOTOR_POR_DEFECTO=atlas

# Ollama local
MODELO_LOCAL=qwen3:8b
URL_OLLAMA=http://127.0.0.1:11434/api/chat

# Modelos de nube
MODELO_NUBE=meta/llama-3.1-70b-instruct
MODELO_GROQ=llama-3.3-70b-versatile

# Proveedores de IA (opcionales; dejar vacíos si no se usan)
NVIDIA_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Búsqueda web opcional
TAVILY_API_KEY=
SEARXNG_URL=

# Herramientas externas opcionales
# Ejemplo: C:\Program Files\poppler\Library\bin
POPPLER_PATH=
ATLAS_OCR_LANG=spa

# Solo para pruebas técnicas de digestión
ATLAS_TEST_MOTOR=atlas
ATLAS_TEST_MODELO=
